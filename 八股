### RTK Query
```jsx
//创建API Slice
// 从特定于 React 的入口点导入 RTK Query 方法
import { createApi, fetchBaseQuery } from '@reduxjs/toolkit/query/react'

// 定义我们的单个 API Slice 对象
export const apiSlice = createApi({
//RTK Query 会产生一个 reducer，这个 reducer 会放在 Redux store 里
  reducerPath: 'api',  //在state.api中
  // 配置所有 API 请求的默认前缀，使用 fetch 来发请求
  baseQuery: fetchBaseQuery({ baseUrl: '/fakeApi' }),
  // 所有 API 请求接口的集合
  endpoints: builder => ({
    //builder.query() 表示 GET 类型
    getPosts: builder.query({
      // 表示 GET /fakeApi/posts
      query: () => '/posts'  //可在()传递参数，在调用useGetPostsQuery也需传递对应参数
    })
    //builder.mutation() 表示 POST/PUT/DELETE
    addPost: builder.mutation({
      //表示 POST /fakeApi/posts
      query: post => ({
       url: '/posts',
       method: 'POST',
        body: post
  })
})
  })
})

// RTK Query 会根据 endpoint 的名字自动生成 React hooks
//例如 名字：getPosts  类型：query => 生成：useGetPostsQuery
export const { useGetPostsQuery } = apiSlice
export const { useAddPostMutation } = apiSlice


```

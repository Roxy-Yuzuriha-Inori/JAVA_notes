//刷新缓存数据
//1.手动刷新
//状态函数refetch，放在button上实现点击手动刷新
<button onClick={refetch}>Refetch Posts</button>
//2.缓存失效自动刷新
export const apiSlice = createApi({
  reducerPath: 'api',
  baseQuery: fetchBaseQuery({ baseUrl: '/fakeApi' }),
  tagTypes: ['Post'],   // ① 声明可能会用到的标签类型

  endpoints: builder => ({
    getPosts: builder.query({
      query: () => '/posts',
      providesTags: ['Post'],  // ② 声明这个查询返回的数据属于哪个标签
    }),

    getPost: builder.query({
      query: postId => `/posts/${postId}`
      // 可不写 providesTags，默认不参与标签系统
    }),

    addNewPost: builder.mutation({
      query: initialPost => ({
        url: '/posts',
        method: 'POST',
        body: initialPost,
      }),
      invalidatesTags: ['Post'],  // ③ 声明这个 Mutation 请求会让哪些标签“失效”
    }),
  }),
})
/*
整体流程：
1.getPosts 查询 → providesTags: ['Post'] 返回的数据都标上post标签
2.当用户点击“Save Post”触发addNewPost Mutation → invalidatesTags: ['Post'] 使标签失效
3.RTK Query 发现Post失效，让有Post标签的请求重新执行，RTK Query 自动执行：getPosts.refetch()
4.<PostsList> 组件自动变灰（isFetching=true），然后重新渲染最新帖子列表
*/
```
1. RTK Query 允许多个组件订阅相同的数据，并且将确保每个唯一的数据集只获取一次。也就是说组件请求数据，RTK Query会先去缓存找有没有对应的数据，没有才会发起请求<br/>
2. 如果在添加任何新的数据订阅之前计时器到期，RTK Query 将自动从缓存中删除该数据(默认为60秒)。60秒到期以后，缓存数据就会标记为过期状态，下次重新渲染或组件挂载时，RTK Query 发现缓存已过期 便会自动触发新请求获取数据 （实现不刷新浏览器更新数据）<br/>
3. 刷新浏览器是将缓存数据全部删除
```jsx
//打标签可以配合id使用
//作用：精细指定要刷新的缓存数据，不影响其他的缓存数据
export const apiSlice = createApi({
  reducerPath: 'api',
  baseQuery: fetchBaseQuery({ baseUrl: '/fakeApi' }),
  tagTypes: ['Post'], // 声明标签类型为Post
  endpoints: builder => ({
    // 1. 获取所有帖子
    getPosts: builder.query({
      query: () => '/posts',
      // 提供标签：给整个列表打'Post'标签，同时给每个帖子打{type: 'Post', id: 帖子ID}标签
      providesTags: (result = [], error, arg) => [
        'Post', // 列表级标签
        ...result.map(({ id }) => ({ type: 'Post', id })) // 每个帖子的精准标签
      ]
    }),
    // 2. 获取单个帖子
    getPost: builder.query({
      query: postId => `/posts/${postId}`,
      // 提供标签：只给当前ID的帖子打精准标签（arg就是传入的postId）
      providesTags: (result, error, arg) => [{ type: 'Post', id: arg }]
    }),
    // 3. 添加新帖子
    addNewPost: builder.mutation({
      query: initialPost => ({ url: '/posts', method: 'POST', body: initialPost }),
      // 使标签失效：让列表级的'Post'标签失效 → 重新获取整个帖子列表
      invalidatesTags: ['Post']
    }),
    // 4. 编辑帖子
    editPost: builder.mutation({
      query: post => ({ url: `posts/${post.id}`, method: 'PATCH', body: post }),
      // 使标签失效：只让被编辑帖子的精准标签失效（arg是传入的post对象，取其id）
      invalidatesTags: (result, error, arg) => [{ type: 'Post', id: arg.id }]
    })
  })
})
```

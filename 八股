// usersSlice.js
// 1. 创建读取 getUsers 缓存的 selector（无参数，缓存键为 undefined）（有参数对应slice里的query()）
export const selectUsersResult = apiSlice.endpoints.getUsers.select()

// 2. 重写 selectAllUsers：从缓存结果中取数据，兜底空数组
export const selectAllUsers = createSelector(
  selectUsersResult,
  //selectUsersResult用于从 RTK Query 的缓存里读取 getUsers 这条接口的查询结果，返回的结果usersResult
  usersResult => usersResult?.data ?? [] // 缓存数据在 result.data 里
)

// 3. 重写 selectUserById：从缓存的用户数组中找指定 ID
export const selectUserById = createSelector(
  //除了最后一个全是选择器
  selectAllUsers,
  (state, userId) => userId,
  (users, userId) => users.find(user => user.id === userId)
)
//endpoint.select(缓存键) 生成的 selector 能精准定位 RTK Query 缓存里的对应数据；
